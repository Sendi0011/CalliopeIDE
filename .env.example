# Server Configuration
PORT=5000
FLASK_ENV=development

# Database
DATABASE_URL=sqlite:///data/calliope.db

# Security Keys (REQUIRED - Generate using the command below)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET_KEY=

# JWT Token Expiration (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Gemini API (REQUIRED - Get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Monitoring & Error Tracking - Backend (Optional)
LOG_LEVEL=INFO                                  # Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SENTRY_ENABLED=false                            # Enable Sentry error tracking
SENTRY_DSN=                                     # Sentry DSN (required if SENTRY_ENABLED=true)
SENTRY_ENVIRONMENT=production                   # Sentry environment name
SENTRY_TRACES_SAMPLE_RATE=0.1                   # Performance monitoring sample rate (0.0-1.0)

# Monitoring & Error Tracking - Frontend (Optional)
NEXT_PUBLIC_SENTRY_ENABLED=false                # Enable Sentry for frontend
NEXT_PUBLIC_SENTRY_DSN=                         # Frontend Sentry DSN
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production       # Frontend environment name
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1       # Frontend traces sample rate
